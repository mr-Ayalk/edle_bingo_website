JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
DESKTOP_API_KEY=change-this-desktop-api-key-for-edle-bingo-app
DEFAULT_DOWNLOAD_PASSWORD=change-this-download-portal-password

